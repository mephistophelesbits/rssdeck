{
  "appId": "com.intellideck.app",
  "productName": "IntelliDeck",
  "copyright": "Copyright © 2026 IntelliDeck",
  "directories": {
    "output": "dist-electron",
    "buildResources": "electron/icons"
  },
  "files": [
    ".electron-dist/**/*",
    "!.electron-dist/**/*.test.js",
    ".next/standalone/**/*",
    "package.json"
  ],
  "npmRebuild": false,
  "afterPack": "./afterPack.js",
  "extraResources": [
    {
      "from": "data",
      "to": "app/data",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "category": "public.app-category.news",
    "icon": "electron/icons/icon.icns",
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64", "x64"]
      }
    ],
    "darkModeSupport": true
  },
  "dmg": {
    "title": "IntelliDeck",
    "backgroundColor": "#09090f",
    "window": {
      "width": 540,
      "height": 380
    }
  },
  "asar": false
}
