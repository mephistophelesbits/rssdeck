{
  "name": "intellideck",
  "version": "3.3.2",
  "private": true,
  "main": ".electron-dist/main.js",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3001 && npm run electron:start\"",
    "electron:compile": "tsc --project tsconfig.electron.json",
    "electron:start": "npm run electron:compile && ELECTRON_IS_DEV=1 npx electron .electron-dist/main.js",
    "electron:prepare": "cp -rp .next/static .next/standalone/.next/ && cp -rp public .next/standalone/ && rm -rf .next/standalone/node_modules/@next/swc-* .next/standalone/node_modules/@img .next/standalone/node_modules/@swc",
    "electron:build": "next build && npm run electron:prepare && npm run electron:compile && npx electron-builder",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "he": "^1.2.0",
    "jsdom": "^27.0.1",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.4.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/d3-geo": "^3.1.0",
    "@types/dompurify": "^3.0.5",
    "@types/he": "^1.2.3",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/topojson-client": "^3.1.5",
    "concurrently": "^9.2.1",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.5"
  }
}
